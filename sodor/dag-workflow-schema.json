{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://dag-workflow.io/schema/v1/workflow.json",
    "title": "DAG Workflow Protocol Schema",
    "description": "DAG 工作流协议 JSON Schema 定义",
    "definitions": {
        "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
            "minLength": 1,
            "maxLength": 63,
            "description": "符合 DNS-1123 规范的名称"
        },
        "duration": {
            "type": "string",
            "pattern": "^([0-9]+d)?([0-9]+h)?([0-9]+m)?([0-9]+s)?$",
            "description": "时长格式，如 30s, 5m, 2h, 1d, 1h30m",
            "examples": [
                "30s",
                "5m",
                "2h",
                "1d",
                "1h30m"
            ]
        },
        "templateVariable": {
            "type": "string",
            "pattern": ".*\\{\\{.*\\}\\}.*",
            "description": "包含模板变量的字符串，如 {{workflow.parameters.xxx}}"
        },
        "metadata": {
            "type": "object",
            "properties": {
                "name": {
                    "$ref": "#/definitions/name",
                    "description": "资源名称，必须唯一"
                },
                "namespace": {
                    "type": "string",
                    "default": "default",
                    "description": "命名空间，用于资源隔离"
                },
                "labels": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "标签，用于分类和筛选"
                },
                "annotations": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "注解，存储额外元信息"
                }
            },
            "required": [
                "name"
            ],
            "additionalProperties": false
        },
        "parameter": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "参数名称"
                },
                "value": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "number"
                        },
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "object"
                        },
                        {
                            "type": "array"
                        }
                    ],
                    "description": "参数值"
                },
                "default": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "number"
                        },
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "object"
                        },
                        {
                            "type": "array"
                        }
                    ],
                    "description": "默认值"
                },
                "description": {
                    "type": "string",
                    "description": "参数描述"
                },
                "enum": {
                    "type": "array",
                    "items": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "number"
                            }
                        ]
                    },
                    "description": "可选值枚举"
                },
                "valueFrom": {
                    "$ref": "#/definitions/valueFrom",
                    "description": "值来源"
                }
            },
            "required": [
                "name"
            ],
            "additionalProperties": false
        },
        "valueFrom": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "从文件路径读取值"
                },
                "parameter": {
                    "type": "string",
                    "description": "从其他参数引用值"
                },
                "expression": {
                    "type": "string",
                    "description": "通过表达式计算值"
                },
                "secretKeyRef": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "key": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "name",
                        "key"
                    ],
                    "description": "从 Secret 引用值"
                }
            },
            "additionalProperties": false
        },
        "artifact": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Artifact 名称"
                },
                "path": {
                    "type": "string",
                    "description": "Artifact 在容器内的路径"
                },
                "from": {
                    "type": "string",
                    "description": "引用其他任务的 Artifact"
                },
                "source": {
                    "$ref": "#/definitions/artifactSource",
                    "description": "Artifact 来源"
                },
                "archive": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": [
                                "tar",
                                "tar.gz",
                                "zip",
                                "none"
                            ],
                            "default": "tar.gz"
                        }
                    },
                    "description": "归档配置"
                }
            },
            "required": [
                "name"
            ],
            "additionalProperties": false
        },
        "artifactSource": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "oss",
                        "http"
                    ],
                    "description": "存储类型"
                },
                "bucket": {
                    "type": "string",
                    "description": "存储桶名称"
                },
                "key": {
                    "type": "string",
                    "description": "对象键/路径"
                },
                "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "HTTP URL"
                }
            },
            "required": [
                "type"
            ],
            "additionalProperties": false
        },
        "arguments": {
            "type": "object",
            "properties": {
                "parameters": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/parameter"
                    },
                    "description": "参数列表"
                },
                "artifacts": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/artifact"
                    },
                    "description": "Artifact 列表"
                }
            },
            "additionalProperties": false
        },
        "inputs": {
            "type": "object",
            "properties": {
                "parameters": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/parameter"
                    },
                    "description": "输入参数列表"
                },
                "artifacts": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/artifact"
                    },
                    "description": "输入 Artifact 列表"
                }
            },
            "additionalProperties": false
        },
        "outputs": {
            "type": "object",
            "properties": {
                "parameters": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/parameter"
                    },
                    "description": "输出参数列表"
                },
                "artifacts": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/artifact"
                    },
                    "description": "输出 Artifact 列表"
                }
            },
            "additionalProperties": false
        },
        "retryStrategy": {
            "type": "object",
            "properties": {
                "limit": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100,
                    "default": 0,
                    "description": "最大重试次数"
                },
                "retryOn": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "timeout",
                            "transient-error",
                            "network-error",
                            "error",
                            "always"
                        ]
                    },
                    "description": "触发重试的错误类型"
                },
                "backoff": {
                    "$ref": "#/definitions/backoff",
                    "description": "退避策略"
                },
                "expression": {
                    "type": "string",
                    "description": "自定义重试条件表达式"
                }
            },
            "additionalProperties": false
        },
        "backoff": {
            "type": "object",
            "properties": {
                "duration": {
                    "$ref": "#/definitions/duration",
                    "default": "1s",
                    "description": "初始等待时间"
                },
                "factor": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 10,
                    "default": 2,
                    "description": "指数因子"
                },
                "maxDuration": {
                    "$ref": "#/definitions/duration",
                    "default": "1m",
                    "description": "最大等待时间"
                }
            },
            "additionalProperties": false
        },
        "continueOn": {
            "type": "object",
            "properties": {
                "failed": {
                    "type": "boolean",
                    "default": false,
                    "description": "任务失败时是否继续"
                },
                "error": {
                    "type": "boolean",
                    "default": false,
                    "description": "任务出错时是否继续"
                }
            },
            "additionalProperties": false
        },
        "resources": {
            "type": "object",
            "properties": {
                "cpu": {
                    "oneOf": [
                        {
                            "type": "string",
                            "pattern": "^[0-9]+m?$"
                        },
                        {
                            "type": "number"
                        }
                    ],
                    "description": "CPU 资源，如 '100m' 或 '1'"
                },
                "memory": {
                    "type": "string",
                    "pattern": "^[0-9]+(Ki|Mi|Gi|Ti)?$",
                    "description": "内存资源，如 '256Mi', '1Gi'"
                },
                "gpu": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "GPU 数量"
                }
            },
            "additionalProperties": false
        },
        "executor": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "http",
                        "script",
                        "function"
                    ],
                    "description": "执行器类型"
                },
                "config": {
                    "oneOf": [
                        {
                            "$ref": "#/definitions/httpConfig"
                        },
                        {
                            "$ref": "#/definitions/scriptConfig"
                        },
                        {
                            "$ref": "#/definitions/functionConfig"
                        }
                    ],
                    "description": "执行器配置"
                }
            },
            "required": [
                "type",
                "config"
            ],
            "additionalProperties": false
        },
        "httpConfig": {
            "type": "object",
            "properties": {
                "method": {
                    "type": "string",
                    "enum": [
                        "GET",
                        "POST",
                        "PUT",
                        "DELETE",
                        "PATCH"
                    ],
                    "default": "GET",
                    "description": "HTTP 方法"
                },
                "url": {
                    "type": "string",
                    "description": "请求 URL"
                },
                "headers": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "请求头"
                },
                "body": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object"
                        }
                    ],
                    "description": "请求体"
                },
                "timeout": {
                    "$ref": "#/definitions/duration",
                    "default": "30s",
                    "description": "请求超时"
                },
                "successCondition": {
                    "type": "string",
                    "default": "response.status >= 200 && response.status < 300",
                    "description": "成功条件表达式"
                }
            },
            "required": [
                "url"
            ],
            "additionalProperties": false
        },
        "scriptConfig": {
            "type": "object",
            "properties": {
                "runtime": {
                    "type": "string",
                    "enum": [
                        "python3",
                        "nodejs",
                        "bash",
                        "sh"
                    ],
                    "description": "脚本运行时"
                },
                "source": {
                    "type": "string",
                    "description": "脚本源码"
                }
            },
            "required": [
                "runtime",
                "source"
            ],
            "additionalProperties": false
        },
        "functionConfig": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "enum": [
                        "file-transfer",
                        "file-download",
                        "file-upload",
                        "notify",
                        "sleep"
                    ],
                    "description": "内置函数名称"
                },
                "arguments": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "函数参数"
                }
            },
            "required": [
                "name"
            ],
            "additionalProperties": false
        },
        "suspendSpec": {
            "type": "object",
            "properties": {
                "duration": {
                    "$ref": "#/definitions/duration",
                    "description": "自动恢复时间，不设置则需手动恢复"
                },
                "message": {
                    "type": "string",
                    "description": "显示给审批者的消息"
                },
                "condition": {
                    "type": "string",
                    "description": "条件满足时自动恢复"
                }
            },
            "additionalProperties": false
        },
        "switchSpec": {
            "type": "object",
            "description": "Switch 条件分支定义，根据表达式结果路由到不同分支执行",
            "properties": {
                "on": {
                    "type": "string",
                    "description": "求值表达式，支持模板变量。结果与 cases[].value 做匹配"
                },
                "cases": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/switchCase"
                    },
                    "minItems": 1,
                    "description": "分支列表，按顺序匹配，首个匹配的 case 胜出"
                },
                "default": {
                    "$ref": "#/definitions/switchBranch",
                    "description": "默认分支，所有 case 都不匹配时执行"
                }
            },
            "required": [
                "on",
                "cases"
            ],
            "additionalProperties": false
        },
        "switchCase": {
            "type": "object",
            "description": "Switch 的单个分支定义，value 和 when 二选一",
            "properties": {
                "value": {
                    "oneOf": [
                        { "type": "string" },
                        { "type": "number" },
                        { "type": "boolean" }
                    ],
                    "description": "匹配值，与 on 表达式结果做相等比较"
                },
                "when": {
                    "type": "string",
                    "description": "条件表达式（与 value 二选一，用于复杂条件）"
                },
                "task": {
                    "$ref": "#/definitions/switchBranch",
                    "description": "匹配时执行的分支"
                }
            },
            "required": [
                "task"
            ],
            "oneOf": [
                {
                    "required": ["value", "task"]
                },
                {
                    "required": ["when", "task"]
                }
            ],
            "additionalProperties": false
        },
        "switchBranch": {
            "type": "object",
            "description": "Switch 分支执行定义，指定要执行的模板和参数",
            "properties": {
                "template": {
                    "type": "string",
                    "description": "引用的模板名称"
                },
                "arguments": {
                    "$ref": "#/definitions/arguments",
                    "description": "传递给模板的参数"
                }
            },
            "required": [
                "template"
            ],
            "additionalProperties": false
        },
        "task": {
            "type": "object",
            "properties": {
                "name": {
                    "$ref": "#/definitions/name",
                    "description": "任务名称，在 DAG 内唯一"
                },
                "template": {
                    "type": "string",
                    "description": "引用的模板名称"
                },
                "dependencies": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "依赖的前置任务名列表"
                },
                "arguments": {
                    "$ref": "#/definitions/arguments",
                    "description": "传递给模板的参数"
                },
                "when": {
                    "type": "string",
                    "description": "条件表达式，为 true 时才执行"
                },
                "continueOn": {
                    "$ref": "#/definitions/continueOn",
                    "description": "继续执行条件"
                },
                "withItems": {
                    "type": "array",
                    "items": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "number"
                            },
                            {
                                "type": "object"
                            }
                        ]
                    },
                    "description": "循环执行，静态列表"
                },
                "withParam": {
                    "type": "string",
                    "description": "循环执行，动态参数引用"
                }
            },
            "required": [
                "name",
                "template"
            ],
            "additionalProperties": false
        },
        "dagSpec": {
            "type": "object",
            "properties": {
                "tasks": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/task"
                    },
                    "minItems": 1,
                    "description": "任务列表"
                },
                "failFast": {
                    "type": "boolean",
                    "default": true,
                    "description": "快速失败，任一任务失败则停止后续任务"
                }
            },
            "required": [
                "tasks"
            ],
            "additionalProperties": false
        },
        "template": {
            "type": "object",
            "properties": {
                "name": {
                    "$ref": "#/definitions/name",
                    "description": "模板名称"
                },
                "inputs": {
                    "$ref": "#/definitions/inputs",
                    "description": "输入定义"
                },
                "outputs": {
                    "$ref": "#/definitions/outputs",
                    "description": "输出定义"
                },
                "dag": {
                    "$ref": "#/definitions/dagSpec",
                    "description": "DAG 定义（DAG 模板）"
                },
                "executor": {
                    "$ref": "#/definitions/executor",
                    "description": "执行器配置（任务模板）"
                },
                "suspend": {
                    "$ref": "#/definitions/suspendSpec",
                    "description": "暂停配置（Suspend 模板）"
                },
                "switch": {
                    "$ref": "#/definitions/switchSpec",
                    "description": "Switch 条件分支（Switch 模板）"
                },
                "queue": {
                    "type": "string",
                    "description": "所属队列名称（任务模板必填）"
                },
                "timeout": {
                    "$ref": "#/definitions/duration",
                    "description": "任务超时"
                },
                "retryStrategy": {
                    "$ref": "#/definitions/retryStrategy",
                    "description": "重试策略"
                },
                "resources": {
                    "$ref": "#/definitions/resources",
                    "description": "资源需求"
                }
            },
            "required": [
                "name"
            ],
            "oneOf": [
                {
                    "required": [
                        "dag"
                    ],
                    "not": {
                        "required": [
                            "executor",
                            "suspend",
                            "switch",
                            "queue"
                        ]
                    }
                },
                {
                    "required": [
                        "executor",
                        "queue"
                    ],
                    "not": {
                        "required": [
                            "dag",
                            "suspend",
                            "switch"
                        ]
                    }
                },
                {
                    "required": [
                        "suspend"
                    ],
                    "not": {
                        "required": [
                            "dag",
                            "executor",
                            "switch",
                            "queue"
                        ]
                    }
                },
                {
                    "required": [
                        "switch"
                    ],
                    "not": {
                        "required": [
                            "dag",
                            "executor",
                            "suspend",
                            "queue"
                        ]
                    }
                }
            ],
            "additionalProperties": false
        },
        "hooks": {
            "type": "object",
            "properties": {
                "onStart": {
                    "$ref": "#/definitions/hookSpec",
                    "description": "工作流开始时触发"
                },
                "onSuccess": {
                    "$ref": "#/definitions/hookSpec",
                    "description": "工作流成功时触发"
                },
                "onFailure": {
                    "$ref": "#/definitions/hookSpec",
                    "description": "工作流业务失败时触发（task 返回 Failed）"
                },
                "onError": {
                    "$ref": "#/definitions/hookSpec",
                    "description": "工作流系统错误时触发（task 返回 Error，如网络超时、executor 崩溃）"
                },
                "onExit": {
                    "$ref": "#/definitions/hookSpec",
                    "description": "工作流退出时触发（无论成功失败）"
                }
            },
            "additionalProperties": false
        },
        "hookSpec": {
            "type": "object",
            "properties": {
                "template": {
                    "type": "string",
                    "description": "钩子模板名称"
                },
                "arguments": {
                    "$ref": "#/definitions/arguments",
                    "description": "传递给模板的参数"
                }
            },
            "required": [
                "template"
            ],
            "additionalProperties": false
        },
        "workflowSpec": {
            "type": "object",
            "properties": {
                "entrypoint": {
                    "type": "string",
                    "description": "入口模板名称"
                },
                "arguments": {
                    "$ref": "#/definitions/arguments",
                    "description": "Workflow 级别参数"
                },
                "globalTimeout": {
                    "$ref": "#/definitions/duration",
                    "default": "1h",
                    "description": "全局超时"
                },
                "retryStrategy": {
                    "$ref": "#/definitions/retryStrategy",
                    "description": "全局重试策略"
                },
                "priority": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 1000,
                    "default": 500,
                    "description": "优先级"
                },
                "queueQuota": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "description": "队列配额限制"
                },
                "failurePolicy": {
                    "type": "string",
                    "enum": [
                        "fail-fast",
                        "continue"
                    ],
                    "default": "fail-fast",
                    "description": "失败策略"
                },
                "maxNestedDepth": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10,
                    "default": 3,
                    "description": "最大嵌套层级"
                },
                "templates": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/template"
                    },
                    "minItems": 1,
                    "description": "模板定义列表"
                },
                "hooks": {
                    "$ref": "#/definitions/hooks",
                    "description": "生命周期钩子"
                },
                "workflowTemplateRef": {
                    "$ref": "#/definitions/workflowTemplateRef",
                    "description": "引用外部模板"
                }
            },
            "oneOf": [
                {
                    "required": [
                        "entrypoint",
                        "templates"
                    ],
                    "not": {
                        "required": [
                            "workflowTemplateRef"
                        ]
                    }
                },
                {
                    "required": [
                        "workflowTemplateRef"
                    ],
                    "not": {
                        "required": [
                            "entrypoint",
                            "templates"
                        ]
                    }
                }
            ],
            "additionalProperties": false
        },
        "workflowTemplateRef": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
