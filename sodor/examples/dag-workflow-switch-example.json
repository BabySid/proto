{
    "apiVersion": "dag/v1",
    "kind": "Workflow",
    "metadata": {
        "name": "image-rewrite-with-switch",
        "namespace": "production",
        "labels": {
            "project": "ai-image",
            "team": "content-generation",
            "feature": "switch-routing"
        },
        "annotations": {
            "description": "AI图片改写流程，使用Switch模板根据provider参数路由到不同AI服务",
            "owner": "ai-team@example.com"
        }
    },
    "spec": {
        "entrypoint": "main",
        "arguments": {
            "parameters": [
                {
                    "name": "provider",
                    "value": "doubao",
                    "enum": ["doubao", "google", "comfyui"],
                    "description": "AI服务提供商"
                },
                {
                    "name": "image_url",
                    "value": "https://cdn.example.com/uploads/source.png",
                    "description": "源图片URL"
                },
                {
                    "name": "prompt",
                    "value": "将图片转换为赛博朋克风格",
                    "description": "改写提示词"
                }
            ]
        },
        "templates": [
            {
                "name": "main",
                "dag": {
                    "tasks": [
                        {
                            "name": "validate",
                            "template": "validate-input-tmpl",
                            "arguments": {
                                "parameters": [
                                    {
                                        "name": "image_url",
                                        "value": "{{workflow.parameters.image_url}}"
                                    }
                                ]
                            }
                        },
                        {
                            "name": "route",
                            "template": "provider-switch",
                            "dependencies": ["validate"],
                            "arguments": {
                                "parameters": [
                                    {
                                        "name": "provider",
                                        "value": "{{workflow.parameters.provider}}"
                                    },
                                    {
                                        "name": "image_url",
                                        "value": "{{tasks.validate.outputs.parameters.validated_url}}"
                                    },
                                    {
                                        "name": "prompt",
                                        "value": "{{workflow.parameters.prompt}}"
                                    }
                                ]
                            }
                        },
                        {
                            "name": "post-process",
                            "template": "post-process-tmpl",
                            "dependencies": ["route"],
                            "arguments": {
                                "parameters": [
                                    {
                                        "name": "result_url",
                                        "value": "{{tasks.route.outputs.parameters.result}}"
                                    },
                                    {
                                        "name": "provider",
                                        "value": "{{workflow.parameters.provider}}"
                                    }
                                ]
                            }
                        },
                        {
                            "name": "callback",
                            "template": "callback-tmpl",
                            "dependencies": ["post-process"],
                            "arguments": {
                                "parameters": [
                                    {
                                        "name": "final_url",
                                        "value": "{{tasks.post-process.outputs.parameters.final_url}}"
                                    }
                                ]
                            }
                        }
                    ]
                }
            },

            {
                "name": "provider-switch",
                "inputs": {
                    "parameters": [
                        { "name": "provider" },
                        { "name": "image_url" },
                        { "name": "prompt" }
                    ]
                },
                "switch": {
                    "on": "{{inputs.parameters.provider}}",
                    "cases": [
                        {
                            "value": "doubao",
                            "task": {
                                "template": "doubao-rewrite-tmpl",
                                "arguments": {
                                    "parameters": [
                                        { "name": "url", "value": "{{inputs.parameters.image_url}}" },
                                        { "name": "prompt", "value": "{{inputs.parameters.prompt}}" }
                                    ]
                                }
                            }
                        },
                        {
                            "value": "google",
                            "task": {
                                "template": "google-rewrite-tmpl",
                                "arguments": {
                                    "parameters": [
                                        { "name": "url", "value": "{{inputs.parameters.image_url}}" },
                                        { "name": "prompt", "value": "{{inputs.parameters.prompt}}" }
                                    ]
                                }
                            }
                        },
                        {
                            "value": "comfyui",
                            "task": {
                                "template": "comfyui-rewrite-tmpl",
                                "arguments": {
                                    "parameters": [
                                        { "name": "url", "value": "{{inputs.parameters.image_url}}" },
                                        { "name": "prompt", "value": "{{inputs.parameters.prompt}}" }
                                    ]
                                }
                            }
                        }
                    ],
                    "default": {
                        "template": "doubao-rewrite-tmpl",
                        "arguments": {
                            "parameters": [
                                { "name": "url", "value": "{{inputs.parameters.image_url}}" },
                                { "name": "prompt", "value": "{{inputs.parameters.prompt}}" }
                            ]
                        }
                    }
                }
            },

            {
                "name": "validate-input-tmpl",
                "inputs": {
                    "parameters": [
                        { "name": "image_url" }
                    ]
                },
                "outputs": {
                    "parameters": [
                        {
                            "name": "validated_url",
                            "valueFrom": { "expression": "outputs.result" }
                        }
                    ]
                },
                "queue": "default",
                "executor": {
                    "type": "function",
                    "config": {
                        "name": "builtin/file/download",
                        "arguments": {
                            "url": "{{inputs.parameters.image_url}}"
                        }
                    }
                },
                "timeout": "30s"
            },

            {
                "name": "doubao-rewrite-tmpl",
                "inputs": {
                    "parameters": [
                        { "name": "url" },
                        { "name": "prompt" }
                    ]
                },
                "outputs": {
                    "parameters": [
                        {
                            "name": "result",
                            "valueFrom": { "expression": "outputs.result_url" }
                        }
                    ]
                },
                "queue": "ai-gpu",
                "executor": {
                    "type": "http",
                    "config": {
                        "method": "POST",
                        "url": "https://api.doubao.com/v1/image/edit",
                        "headers": {
                            "Authorization": "Bearer {{secrets.doubao-api-key}}",
                            "Content-Type": "application/json"
                        },
                        "body": {
                            "image_url": "{{inputs.parameters.url}}",
                            "prompt": "{{inputs.parameters.prompt}}",
                            "model": "doubao-seedream-3-0-t2i-250415"
                        },
                        "timeout": "120s",
                        "successCondition": "response.status == 200"
                    }
                },
                "retryStrategy": {
                    "limit": 3,
                    "retryOn": ["transient-error", "timeout"],
                    "backoff": {
                        "duration": "10s",
                        "factor": 2,
                        "maxDuration": "2m"
                    }
                },
                "timeout": "5m",
                "resources": {
                    "gpu": 1
                }
            },

            {
                "name": "google-rewrite-tmpl",
                "inputs": {
                    "parameters": [
                        { "name": "url" },
                        { "name": "prompt" }
                    ]
                },
                "outputs": {
                    "parameters": [
                        {
                            "name": "result",
                            "valueFrom": { "expression": "outputs.result_url" }
                        }
                    ]
                },
                "queue": "ai-gpu",
                "executor": {
                    "type": "http",
                    "config": {
                        "method": "POST",
                        "url": "https://generativelanguage.googleapis.com/v1/models/imagen-3.0:predict",
                        "headers": {
                            "Authorization": "Bearer {{secrets.google-api-key}}",
                            "Content-Type": "application/json"
                        },
                        "body": {
                            "instances": [
                                {
                                    "image": { "gcsUri": "{{inputs.parameters.url}}" },
                                    "prompt": "{{inputs.parameters.prompt}}"
                                }
                            ]
                        },
                        "timeout": "180s",
                        "successCondition": "response.status == 200"
                    }
                },
                "retryStrategy": {
                    "limit": 2,
                    "retryOn": ["transient-error", "timeout"],
                    "backoff": {
                        "duration": "15s",
                        "factor": 2,
                        "maxDuration": "3m"
                    }
                },
                "timeout": "5m",
                "resources": {
                    "gpu": 1
                }
            },

            {
                "name": "comfyui-rewrite-tmpl",
                "inputs": {
                    "parameters": [
                        { "name": "url" },
                        { "name": "prompt" }
                    ]
                },
                "outputs": {
                    "parameters": [
                        {
                            "name": "result",
                            "valueFrom": { "expression": "outputs.result_url" }
                        }
                    ]
                },
                "queue": "comfyui",
                "executor": {
                    "type": "http",
                    "config": {
                        "method": "POST",
                        "url": "http://comfyui-internal:8188/api/prompt",
                        "headers": {
                            "Content-Type": "application/json"
                        },
                        "body": {
                            "workflow_id": "img-rewrite-v2",
                            "input_image": "{{inputs.parameters.url}}",
                            "prompt": "{{inputs.parameters.prompt}}"
                        },
                        "timeout": "300s",
                        "successCondition": "response.status == 200"
                    }
                },
                "retryStrategy": {
                    "limit": 2,
                    "retryOn": ["transient-error", "network-error"],
                    "backoff": {
                        "duration": "30s",
                        "factor": 2,
                        "maxDuration": "5m"
                    }
                },
                "timeout": "10m"
            },

            {
                "name": "post-process-tmpl",
                "inputs": {
                    "parameters": [
                        { "name": "result_url" },
                        { "name": "provider" }
                    ]
                },
                "outputs": {
                    "parameters": [
                        {
                            "name": "final_url",
                            "valueFrom": { "expression": "outputs.final_url" }
                        }
                    ]
                },
                "queue": "default",
                "executor": {
                    "type": "function",
                    "config": {
                        "name": "custom/image/post-process",
                        "arguments": {
                            "source_url": "{{inputs.parameters.result_url}}",
                            "provider": "{{inputs.parameters.provider}}",
                            "operations": ["resize", "watermark", "optimize"]
                        }
                    }
                },
                "timeout": "1m"
            },

            {
                "name": "callback-tmpl",
                "inputs": {
                    "parameters": [
                        { "name": "final_url" }
                    ]
                },
                "queue": "default",
                "executor": {
                    "type": "http",
                    "config": {
                        "method": "POST",
                        "url": "https://api.example.com/webhook/image-complete",
                        "headers": {
                            "Content-Type": "application/json"
                        },
                        "body": {
                            "status": "completed",
                            "result_url": "{{inputs.parameters.final_url}}",
                            "workflow_name": "{{workflow.name}}",
                            "workflow_uid": "{{workflow.uid}}"
                        },
                        "timeout": "10s"
                    }
                },
                "retryStrategy": {
                    "limit": 3,
                    "backoff": {
                        "duration": "5s",
                        "factor": 2,
                        "maxDuration": "1m"
                    }
                }
            }
        ]
    }
}
